<?xml version="1.0" encoding="UTF-8"?>
<extension type="module" client="site" method="upgrade">
    <name>MOD_KINOPLANSCHEDULE</name>
    <author>Sergey Kuznetsov</author>
    <creationDate>2026-05</creationDate>
    <copyright>(C) 2024 Sergey Kuznetsov</copyright>
    <license>GNU General Public License version 2 or later; see LICENSE.txt</license>
    <authorEmail>mediafoks@google.com</authorEmail>
    <authorUrl>https://github.com/mediafoks</authorUrl>
    <version>1.1.0</version>
    <description>MOD_KINOPLANSCHEDULE_XML_DESCRIPTION</description>
    <namespace path="src">Joomla\Module\KinoplanSchedule</namespace>

    <files>
        <folder module="mod_kinoplanschedule">services</folder>
        <folder>src</folder>
        <folder>tmpl</folder>
    </files>

    <languages>
        <language tag="en-GB">language/en-GB/mod_kinoplanschedule.ini</language>
        <language tag="en-GB">language/en-GB/mod_kinoplanschedule.sys.ini</language>
        <language tag="ru-RU">language/ru-RU/mod_kinoplanschedule.ini</language>
        <language tag="ru-RU">language/ru-RU/mod_kinoplanschedule.sys.ini</language>
    </languages>

    <help key="Site_Modules:_Kinoplan_-_Schedule" />

    <config>
        <fields name="params">
            <fieldset name="basic">

                <field name="limit" type="number" default="12" label="Movies Limit" />

                <field name="show_description" type="radio" default="1" label="Show Description">
                    <option value="1">Yes</option>

                    <option value="0">No</option>
                </field>

                <field name="show_genres" type="radio" default="1" label="Show Genres">
                    <option value="1">Yes</option>

                    <option value="0">No</option>
                </field>

                <field name="swiper" type="radio" default="1" label="Enable Swiper Carousel">
                    <option value="1">Yes</option>

                    <option value="0">No</option>
                </field>

            </fieldset>
            <fieldset name="advanced">
                <field name="layout" type="modulelayout" label="JFIELD_ALT_LAYOUT_LABEL" class="form-select" validate="moduleLayout" />

                <field name="moduleclass_sfx" type="textarea" label="COM_MODULES_FIELD_MODULECLASS_SFX_LABEL" rows="3" validate="CssIdentifier" />

                <field name="owncache" type="list" label="COM_MODULES_FIELD_CACHING_LABEL" default="1" filter="integer" validate="options">
                    <option value="1">JGLOBAL_USE_GLOBAL</option>
                    <option value="0">COM_MODULES_FIELD_VALUE_NOCACHING</option>
                </field>

                <field name="cache_time" type="number" label="COM_MODULES_FIELD_CACHE_TIME_LABEL" default="900" filter="integer" />
            </fieldset>

        </fields>
    </config>
</extension>